// Fonction d'autorisation
function checkAuthorization(email) {
  if (!email) return false;
  const cleanEmail = email.toString().toLowerCase().trim();
  return CONFIG.ALLOWED_EMAILS.some(
    allowed => allowed.toLowerCase().trim() === cleanEmail
  );
}

function verifyAuthorization() {
  const email = Session.getEffectiveUser().getEmail();
  if (!checkAuthorization(email)) {
    throw new Error(`Accès refusé pour ${email}`);
  }
  return true;
}

function onOpen() {
  try {

      SpreadsheetApp.getUi()
        .createMenu("Préparation AVII")
        .addItem("Ouvrir", "openSidebar")
        .addToUi();
    }
  } catch (e) {
    console.error("Erreur dans onOpen:", e);
  }
}

function openSidebar() {

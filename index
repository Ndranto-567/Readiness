function submitForm() {
  const today = new Date().toISOString().split('T')[0];
  const dateDebut = document.getElementById('col_AE').value;
  
  // Validation de la date de début
  if (dateDebut && dateDebut < today) {
    alert("La date de début doit être aujourd'hui ou ultérieure");
    document.getElementById('col_AE').value = today;
    return false; // Empêche la soumission
  }

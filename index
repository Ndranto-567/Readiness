document.addEventListener('DOMContentLoaded', function() {
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    google.script.run
      .withSuccessHandler(initApplication)
      .withFailureHandler(showAuthError)
      .verifyAuthorization();
  } else {
    // Mode éditeur
    initApplication();
  }
});

function initApplication() {
  loadDataFromServer();
}

function showAuthError(error) {
  console.error("Erreur d'autorisation:", error);
  document.body.innerHTML = `
    <div style="padding: 20px; text-align: center;">
      <h2 style="color: #d32f2f;">Accès non autorisé</h2>
      <p>${error.message || "Vous n'avez pas les droits nécessaires."}</p>
      <p>Contactez l'administrateur si vous pensez qu'il s'agit d'une erreur.</p>
    </div>
  `;
}


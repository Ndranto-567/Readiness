function getDropdownData() {
  const sheet = SpreadsheetApp.openById(sheetID).getSheetByName(sheetName);
  const data = sheet.getDataRange().getValues();
  const niveaux = [...new Set(data.slice(1).map(row => row[1]).filter(v => v && v.trim() !== ""))];
  const regions = [...new Set(data.slice(1).map(row => `${row[1]}|${row[2]}`))].map(r => {
    const [niveau, region] = r.split('|');
    return { niveau, region };
  });

  const districts = data.slice(1).map(row => ({
    niveau: row[1],
    region: row[2],
    district: row[3],
  }));

  return { niveaux, regions, districts };
}

function getRowData(niveau, region, district) {
  const sheet = SpreadsheetApp.openById(sheetID).getSheetByName(sheetName);
  const data = sheet.getDataRange().getValues();
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    if (row[1] === niveau && row[2] === region && row[3] === district) {
      const result = row.slice(4, 31); // De E à AE
      
      // Formatage explicite de la date de début (AE, index 26 dans result)
      if (result[26] instanceof Date) {
        result[26] = Utilities.formatDate(result[26], Session.getScriptTimeZone(), "yyyy-MM-dd");
      }
      
      return result;
    }
  }
  return [];
}

function saveRowData(niveau, region, district, values) {
  const sheet = SpreadsheetApp.openById(sheetID).getSheetByName(sheetName);
  const data = sheet.getDataRange().getValues();

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    if (row[1] === niveau && row[2] === region && row[3] === district) {
      for (let j = 0; j < values.length; j++) {
        sheet.getRange(i + 1, 5 + j).setValue(values[j]); // colonnes E = 5
      }
      sheet.getRange(i + 1, 31).setValue(new Date()); // mise à jour date en colonne AF
      // Met à jour la cellule A2 de "Dashboard District"
      const updateSuccess = updateDashboardDistrict(region);
      console.log("Résultat de updateDashboardDistrict :", updateSuccess);
      break;
    }
  }
}

function getDataByLocalite(localite) {
  const sheet = SpreadsheetApp.openById(sheetID).getSheetByName(sheetName);
  const data = sheet.getDataRange().getValues();
  
  const searchTerm = localite.toString().toUpperCase().trim();

  for (let i = 1; i < data.length; i++) {
    const rowValue = data[i][0] ? data[i][0].toString().toUpperCase().trim() : '';
    
    if (rowValue === searchTerm) {
      console.log("Correspondance trouvée ligne:", i+1);
      const result = data[i].slice(4, 31);
      
      // Conversion explicite pour le transfert
      return result.map(item => {
        if (item instanceof Date) {
          return Utilities.formatDate(item, Session.getScriptTimeZone(), "yyyy-MM-dd");
        }
        return item !== null && item !== undefined ? item.toString() : "";
      });
    }
  }
  return null;
}

function updateDashboardDistrict(region) {
  try {
    const ss = SpreadsheetApp.openById(sheetID);
    console.log("Nom de la feuille recherchée : 'Dashboard District'");
    
    const dashboardSheet = ss.getSheetByName("Dashboard District");
    
    if (!dashboardSheet) {
      console.error("ERREUR : La feuille 'Dashboard District' est introuvable. Feuilles disponibles :");
      console.log(ss.getSheets().map(s => s.getName()));
      throw new Error("Feuille 'Dashboard District' introuvable");
    }
    
    console.log(`Tentative d'écriture dans A2 avec la valeur : ${region}`);
    dashboardSheet.getRange("A2").setValue(region);
    console.log("Écriture réussie dans A2");
    
    return true;
  } catch (e) {
    console.error("Échec de updateDashboardDistrict :", e.message);
    return false;
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Écoute les changements sur tous les groupes de radio
  document.querySelectorAll('.radio-group').forEach(group => {
    group.addEventListener('change', function(e) {
      const container = e.target.closest('.field-container');
      const selectedValue = e.target.value;
      
      // Reset des classes
      container.classList.remove('response-yes', 'response-no', 'response-na');
      
      // Ajoute la classe appropriée
      if (selectedValue === "1") {
        container.classList.add('response-yes');
      } else if (selectedValue === "0") {
        container.classList.add('response-no');
      } else {
        container.classList.add('response-na');
      }
    });
  });
});

  document.addEventListener('DOMContentLoaded', function() {
    // Supprime le footer Google après un délai
    setTimeout(function() {
      const googleFooters = document.querySelectorAll('div[aria-label="Signaler un abus"]');
      googleFooters.forEach(footer => footer.style.display = 'none');
      
      // Alternative pour les iframes
      const iframes = document.querySelectorAll('iframe');
      iframes.forEach(iframe => {
        if (iframe.src.includes('signaler')) {
          iframe.remove();
        }
      });
    }, 1000); // Délai pour laisser le temps au chargement
  });

